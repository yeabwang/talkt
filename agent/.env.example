# TalkT agent worker — copy to .env.local and fill in.
# LiveKit Inference bills through these credentials; no provider API keys here.
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Where the worker POSTs the session-ended callback (the Next app).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret authenticating the worker -> app /api/internal/session-ended call.
# Must match the app's INTERNAL_API_SECRET. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=""
