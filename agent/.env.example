# TalkT agent worker — copy to .env.local and fill in.
# LiveKit Inference bills through these credentials; no provider API keys here.
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# Where the worker POSTs the session-ended callback (the Next app).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Shared secret authenticating the worker -> app /api/internal/session-ended call.
# Must match the app's INTERNAL_API_SECRET. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=""

# ── LiveKit Inference model/provider choices ──────────
# Model IDs include the provider prefix. Defaults shown here follow the LiveKit
# Inference docs; change them per environment without editing source.
LIVEKIT_AGENT_STT_MODEL="auto"
# Use "job" to pass the interview language, or a fixed code like "multi"/"en".
LIVEKIT_AGENT_STT_LANGUAGE="job"
LIVEKIT_AGENT_LLM_MODEL="openai/gpt-5.3-chat-latest"

# TTS can use one global voice, or the persona/language catalog below.
# LIVEKIT_AGENT_TTS_MODEL="cartesia/sonic-3"
# LIVEKIT_AGENT_TTS_VOICE=""
# Use "job" to pass the interview language, "none" to omit, or a fixed code.
LIVEKIT_AGENT_TTS_LANGUAGE="job"

# Persona + language voice catalog. Language keys are matched exact first
# (for example "pt-br"), then by base language ("pt"). Each model value can
# point at any LiveKit Inference TTS provider/model available to your project.
LIVEKIT_AGENT_TTS_VOICE_CATALOG={"defaultModel":"cartesia/sonic-3","defaultPersona":"adi","personas":{"adi":{"voice":"5c5ad5e7-1020-476b-8b91-fdcbe9cc313c"},"ren":{"voice":"9626c31c-bec5-4cca-baa8-f8ba9e84c8bc"},"kai":{"voice":"a167e0f3-df7e-4d52-a9c3-f949145efdab"},"mira":{"voice":"f31cc6a7-c1e8-4764-980c-60a361443dd1"}},"languages":{"es":{"ren":{"model":"inworld/inworld-tts-1","voice":"Diego"},"kai":{"model":"elevenlabs/eleven_turbo_v2_5","voice":"cjVigY5qzO86Huf0OWal"}}}}
