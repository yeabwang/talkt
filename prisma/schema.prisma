// TalkT relational metadata and structured feedback.
// Large artifacts live outside Postgres; only blob URLs are stored here.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InterviewType {
  template
  custom
}

enum Visibility {
  public
  private
}

enum AttemptStatus {
  in_progress
  analyzing
  ready
  failed
  // Candidate left before a scoreable interview completed.
  abandoned
}

// Profile row keyed by Clerk user id.
model User {
  id        String   @id
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  interviews Interview[]
  attempts   Attempt[]
  votes      Vote[]
}

model Interview {
  id          String        @id @default(cuid())
  ownerId     String?
  owner       User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  subtitle    String?
  role        String?
  topic       String?
  difficulty  String?
  blurb       String?
  minutes     Int?
  focus       String[]      @default([])
  type        InterviewType @default(custom)
  visibility  Visibility    @default(private)
  language    String        @default("en")
  dimensions  Json          @default("[]")
  questions   Json
  voiceConfig Json?

  // Publishing and attribution for custom interviews promoted to the directory.
  publishedAt DateTime?
  authorName  String?
  anonymous   Boolean   @default(false)

  // Up/down vote tallies are denormalized for fast sorted directory reads.
  upvotes   Int   @default(0)
  downvotes Int   @default(0)
  rankScore Float @default(0)

  // Heavily downvoted templates are hidden and flagged for review.
  flagged   Boolean   @default(false)
  flaggedAt DateTime?

  createdAt DateTime @default(now())

  attempts Attempt[]
  votes    Vote[]

  @@index([ownerId])
  @@index([type, visibility])
  // Directory reads filter visibility/flags and sort by rank.
  @@index([flagged, visibility, type, rankScore])
}

// One up/down vote per user per interview; votes are toggleable and clearable.
model Vote {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  value       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, interviewId])
  @@index([interviewId])
}

model Attempt {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId       String
  interview         Interview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  status            AttemptStatus @default(in_progress)
  // Correlates Vapi callbacks to attempts; assistants are ephemeral.
  vapiCallId        String?       @unique
  vapiAssistantId   String?
  startedAt         DateTime      @default(now())
  endedAt           DateTime?
  transcriptBlobUrl String?

  feedback Feedback?

  @@index([interviewId])
  // Graded history reads.
  @@index([userId, status, startedAt])
  // Recommendation profile reads.
  @@index([userId, startedAt])
}

// Interviewer personas shown in the UI; Vapi voices resolve through lib/vapi/voices.ts.
model VoiceAgent {
  key       String   @id
  name      String
  tone      String
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id              String   @id @default(cuid())
  attemptId       String   @unique
  attempt         Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  overallScore    Float
  summary         String   @default("")
  dimensionScores Json
  strengths       String[]
  improvements    String[]
  perQuestion     Json
  rawBlobUrl      String?
  createdAt       DateTime @default(now())
}
