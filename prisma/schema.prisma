// TalkT — Prisma schema
// Relational metadata + structured feedback. Bulky artifacts (transcripts,
// raw DeepSeek output) live in Vercel Blob; only blob URLs are stored here.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InterviewType {
  template
  custom
}

enum Visibility {
  public
  private
}

enum AttemptStatus {
  in_progress
  analyzing
  ready
  failed
}

// Thin profile row keyed by Clerk user id.
model User {
  id        String   @id // Clerk user id
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  interviews Interview[] // custom interviews this user owns
  attempts   Attempt[]
  votes      Vote[]
}

model Interview {
  id          String        @id @default(cuid())
  ownerId     String? // null = system template
  owner       User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  subtitle    String? // short tagline under the title
  role        String?
  topic       String? // used as the directory "category" facet
  difficulty  String?
  blurb       String? // one-line description shown on the card/detail
  minutes     Int? // estimated spoken duration
  focus       String[]      @default([]) // themes the interview leans on
  type        InterviewType @default(custom)
  visibility  Visibility    @default(private)
  language    String        @default("en") // ISO 639-1; controls question gen, interviewer voice, report
  dimensions  Json          @default("[]") // 4 core scoring dims LLM picks per role: [{ key, label, weight? }]
  questions   Json // ordered Question[]: { id, text, idealAnswerHint? }
  voiceConfig Json? // { voiceId } — language promoted to its own column

  // Publishing + attribution (a custom interview becomes a public template).
  publishedAt DateTime? // when the owner published it public; null = never published
  authorName  String? // snapshot display-name credit shown on card/detail; null when anonymous
  anonymous   Boolean   @default(false) // published without attribution (carries a ranking down-weight)

  // Reddit-style voting tallies (denormalized for transparent counts + sorted reads).
  upvotes   Int   @default(0)
  downvotes Int   @default(0)
  rankScore Float @default(0) // Wilson lower bound with anonymity down-weight baked in

  // Auto-takedown: heavily downvoted templates are hidden and flagged for admin review.
  flagged   Boolean   @default(false)
  flaggedAt DateTime?

  createdAt DateTime @default(now())

  attempts Attempt[]
  votes    Vote[]

  @@index([ownerId])
  @@index([type, visibility])
  // Directory reads: filter out flagged/private, order by rankScore.
  @@index([flagged, visibility, type, rankScore])
}

// One up/down vote per user per interview. Reddit-style; toggleable/clearable.
model Vote {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  value       Int // 1 = up, -1 = down
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, interviewId]) // enforces one vote per user per interview
  @@index([interviewId])
}

model Attempt {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId       String
  interview         Interview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  status            AttemptStatus @default(in_progress)
  vapiCallId        String?       @unique
  startedAt         DateTime      @default(now())
  endedAt           DateTime?
  transcriptBlobUrl String?

  feedback Feedback?

  @@index([interviewId])
  // History list: userId + status filter, startedAt sort (listUserAttempts).
  @@index([userId, status, startedAt])
  // Recommendation facets: userId filter, startedAt sort (listAttemptFacets).
  @@index([userId, startedAt])
}

// Cached pool of usable voice agents. The lobby/start path resolves a persona
// (key) to a live provider voice id; availability is re-checked against Vapi and
// a dead voice id is swapped for a working one, then this row is updated so the
// next user gets the fresh value without another provider round-trip.
model VoiceAgent {
  key         String   @id // stable persona key surfaced in the UI: adi/ren/kai/mira
  name        String
  tone        String
  provider    String   @default("11labs") // Vapi voice provider
  voiceId     String // provider voice id used to build the transient assistant
  language    String   @default("en") // ISO 639-1 the voice is tuned for
  available   Boolean  @default(true) // last known availability against the provider
  lastChecked DateTime? // when availability was last verified (TTL-gated)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Feedback {
  id              String   @id @default(cuid())
  attemptId       String   @unique
  attempt         Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  overallScore    Float
  summary         String   @default("")
  dimensionScores Json // keyed to Interview.dimensions: { [dimKey]: { score, note } }
  strengths       String[]
  improvements    String[]
  perQuestion     Json // [{ questionId, ratingScore, modelAnswer, critique }]
  rawBlobUrl      String?
  createdAt       DateTime @default(now())
}
