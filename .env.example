# TalkT — environment template
# Copy to .env.local and fill real values. Never commit .env.local.

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Clerk (auth) ──────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ── Database (PostgreSQL + Prisma) ────────────────────
# Pooled connection for the app
DATABASE_URL="postgresql://user:password@host:5432/talkt?sslmode=require"
# Direct (unpooled) connection for migrations
DIRECT_URL="postgresql://user:password@host:5432/talkt?sslmode=require"

# ── Vercel Blob (artifacts: transcripts, raw feedback) ─
# https://vercel.com → Storage → Blob → tokens
BLOB_READ_WRITE_TOKEN=""

# ── DeepSeek (question gen + transcript analysis) ─────
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ── Vapi (voice) ──────────────────────────────────────
# Private key: server-side only (build transient assistant, REST)
VAPI_PRIVATE_KEY=""
# Public key: client-side Vapi Web SDK
NEXT_PUBLIC_VAPI_PUBLIC_KEY=""
# Secret used to verify inbound end-of-call webhook signature
VAPI_WEBHOOK_SECRET=""
