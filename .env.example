# TalkT — environment template
# Copy to .env.local and fill real values. Never commit .env.local.

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Clerk (auth) ──────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ── Database (PostgreSQL + Prisma) ────────────────────
# Pooled connection for the app
DATABASE_URL="postgresql://user:password@host:5432/talkt?sslmode=require"
# Direct (unpooled) connection for migrations
DIRECT_URL="postgresql://user:password@host:5432/talkt?sslmode=require"

# ── Vercel Blob (artifacts: transcripts, raw feedback) ─
# https://vercel.com → Storage → Blob → tokens
BLOB_READ_WRITE_TOKEN=""

# ── DeepSeek (question gen + transcript analysis) ─────
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ── Vapi (voice) ──────────────────────────────────────
# https://dashboard.vapi.ai → API Keys
VAPI_PRIVATE_KEY=""            # server-side: create/delete ephemeral assistants
NEXT_PUBLIC_VAPI_PUBLIC_KEY="" # client-side: @vapi-ai/web call auth
# Shared secret Vapi echoes back on the webhook (X-Vapi-Secret). Must equal the
# assistant's server.secret. In production a missing value fails the webhook closed.
VAPI_WEBHOOK_SECRET=""
# Interviewer model + transcriber — Vapi-native, billed by Vapi (no provider key).
# gpt-4.1-mini: Vapi's pick for natural, instruction-following voice conversation.
VAPI_MODEL_PROVIDER="openai"
VAPI_MODEL="gpt-4.1-mini"
VAPI_TRANSCRIBER_PROVIDER="deepgram"
VAPI_TRANSCRIBER_MODEL="nova-3"
# Optional overrides
# VAPI_VOICE_CATALOG=""        # JSON persona→voice catalog (see lib/vapi/voices.ts)
