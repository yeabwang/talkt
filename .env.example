# TalkT environment template
# Copy to .env.local and fill real values. Never commit .env.local.

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Clerk auth
# Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Database
# Pooled connection for the app
DATABASE_URL="postgresql://user:password@host:5432/talkt?sslmode=require"
# Direct (unpooled) connection for migrations
DIRECT_URL="postgresql://user:password@host:5432/talkt?sslmode=require"

# Vercel Blob
# Dashboard: https://vercel.com
BLOB_READ_WRITE_TOKEN=""

# DeepSeek
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# Vapi voice
# Dashboard: https://dashboard.vapi.ai
VAPI_PRIVATE_KEY=""            # server-side: create/delete ephemeral assistants
NEXT_PUBLIC_VAPI_PUBLIC_KEY="" # client-side: @vapi-ai/web call auth
# Optional public callback base. Use a tunnel for local webhook delivery.
# VAPI_WEBHOOK_URL="https://your-public-tunnel.example.com"
# Shared callback secret. Production rejects callbacks when this is blank.
VAPI_WEBHOOK_SECRET=""
# Optional Vapi credential for X-Vapi-Secret or Authorization: Bearer auth.
# VAPI_WEBHOOK_CREDENTIAL_ID=""
# Interviewer model and transcriber, billed through Vapi.
VAPI_MODEL_PROVIDER="openai"
VAPI_MODEL="gpt-4.1"
VAPI_TRANSCRIBER_PROVIDER="deepgram"
VAPI_TRANSCRIBER_MODEL="nova-3"
# Optional overrides
# VAPI_VOICE_CATALOG=""        # JSON persona voice catalog (see lib/vapi/voices.ts)
