# TalkT — environment template
# Copy to .env.local and fill real values. Never commit .env.local.

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Clerk (auth) ──────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ── Database (PostgreSQL + Prisma) ────────────────────
# Pooled connection for the app
DATABASE_URL="postgresql://user:password@host:5432/talkt?sslmode=require"
# Direct (unpooled) connection for migrations
DIRECT_URL="postgresql://user:password@host:5432/talkt?sslmode=require"

# ── Vercel Blob (artifacts: transcripts, raw feedback) ─
# https://vercel.com → Storage → Blob → tokens
BLOB_READ_WRITE_TOKEN=""

# ── DeepSeek (question gen + transcript analysis) ─────
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"

# ── LiveKit (voice) ───────────────────────────────────
# Server URL the browser dials and the worker registers with.
LIVEKIT_URL="wss://your-project.livekit.cloud"
# API key/secret: server-side only (mint room-join tokens + agent dispatch).
LIVEKIT_API_KEY=""
LIVEKIT_API_SECRET=""

# ── Internal worker callback ──────────────────────────
# Shared secret the interviewer worker echoes on POST /api/internal/session-ended
# (x-internal-secret). Must match the worker's INTERNAL_API_SECRET. Generate a
# long random value; in production a missing value makes the endpoint fail closed.
INTERNAL_API_SECRET=""
